generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum EventType {
  BIRTHDAY
  ANNIVERSARY
  APOLOGY
  SPECIAL
  CUSTOM
}

enum RelationType {
  GIRLFRIEND_BOYFRIEND
  BEST_FRIEND
  CLOSE_FRIEND
  FAMILY
  CRUSH
  CUSTOM
}

enum ThemeKind {
  DAILY
  MILESTONE
  CELEBRATION
}

enum QuoteKind {
  DAILY
  MILESTONE
  CELEBRATION
}

model Person {
  id                      String     @id @default(auto()) @map("_id") @db.ObjectId
  name                    String
  slug                    String
  relationType            RelationType
  eventType               EventType  @default(BIRTHDAY)
  targetDate              DateTime
  useExactTime            Boolean    @default(false)
  isRecurringYearly       Boolean    @default(true)
  accessToken             String     @unique
  coverImageUrl           String?
  customBgImageUrl        String?
  customQuote             String?
  welcomeMessage            String?
  celebrationPopupMessage   String?
  celebrationPopupImageUrl  String?
  preferredThemeId          String?
  accessCodeHash          String?
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt
  accessLogs              AccessLog[]

  @@unique([slug, accessToken])
  @@index([slug])
}

model ThemeSet {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  relationType  RelationType
  eventType     EventType    @default(BIRTHDAY)
  name          String
  colors        Json
  bgImageUrl    String?
  overlayEmoji  String?
  animationType String       @default("fade")
  kind          ThemeKind    @default(DAILY)
  milestoneDays Int?
  sortOrder     Int          @default(0)
}

model Quote {
  id            String       @id @default(auto()) @map("_id") @db.ObjectId
  relationType  RelationType
  text          String
  kind          QuoteKind    @default(DAILY)
  dayOffset     Int?
  milestoneDays Int?
}

model AdminUser {
  id           String @id @default(auto()) @map("_id") @db.ObjectId
  email        String @unique
  passwordHash String
}

model AccessLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  personId   String   @db.ObjectId
  person     Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  visitorKey String?
  viewedAt   DateTime @default(now())

  @@index([personId])
  @@index([personId, visitorKey])
}
